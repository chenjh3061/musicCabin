			"path": "pages/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path" : "pages/menu",
			"style" : 
			{
				"navigationBarTitleText" : "菜单界面",
				"enablePullDownRefresh" : true
			}
		},
		{
			"path": "pages/special",
			"style": {
				"navigationBarTitleText": "特产页面",
				"enablePullDownRefresh": true
			}
		},
		{
			"path" : "pages/userPage",
			"style" : 
			{
				"navigationBarTitleText" : "用户页面",
				"enablePullDownRefresh" : false
			}
		}
	],
	"tabBar": {
	    "color": "#7f7f7f",
