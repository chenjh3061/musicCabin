	        "iconPath": "static/tabs/post.png",
	        "selectedIconPath": "static/tabs/post-active.png"
	      },
	      {
	        "pagePath": "pages/demo1",
	        "text": "商城",
	        "iconPath": "static/tabs/mall.png",
	        "selectedIconPath": "static/tabs/mall-active.png"
	      },
	      {
	        "pagePath": "pages/userPage",
	        "text": "我的",
	        "iconPath": "static/tabs/user.png",
	        "selectedIconPath": "static/tabs/user-active.png"
	      }
	    ]
	  },
	"globalStyle": {
		"navigationBarTextStyle": "black",
